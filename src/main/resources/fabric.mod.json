{
    "schemaVersion": 1,
    "id": "chat-translator-mod",
    "version": "${version}",
    "name": "Translator Mod",
    "description": "A simple mod to translate text in Fabric!",
    "authors": [
        "Nuyuchi"
    ],
    "contact": {
        "homepage": "https://fabricmc.net/",
        "sources": "https://github.com/FabricMC/fabric-example-mod"
    },
    "license": "Apache-2.0",
    "icon": "assets/chat-translator-mod/icon.png", 
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.nuyuchi.translator.TranslatorMod"
        ],
        "client": [
            "com.nuyuchi.translator.TranslatorModClient"
        ],
        "modmenu": [
            "com.nuyuchi.translator.client.TranslatorModMenuIntegration"
        ]
    },
    "mixins": [
        "chat-translator-mod.mixins.json",
        {
            "config": "chat-translator-mod.client.mixins.json",
            "environment": "client"
        }
    ],
    "depends": {
        "fabricloader": ">=0.18.2",
        "minecraft": "~1.21", 
        "java": ">=21",
        "fabric-api": "*"
    }
}